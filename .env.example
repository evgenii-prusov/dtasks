# Copy to .env and fill in real values. .env is gitignored — never commit it.

# Public hostname — used to build DTASKS_PUBLIC_URL. HTTPS termination and
# reverse proxying for it live in the dinfra edge stack
# (https://github.com/evgenii-prusov/dinfra), not in this compose file.
DOMAIN=dtasks.example.com

# App
DTASKS_INVITE_CODE=change-me

# OAuth social login (Google / GitHub) — see docs/deploy.md "OAuth providers"
# for how to register these. Leaving either pair unset disables that
# provider's "Continue with ..." button and 404s its endpoints; the two
# providers are independent, so you can configure just one.
# DTASKS_GOOGLE_CLIENT_ID=
# DTASKS_GOOGLE_CLIENT_SECRET=
# DTASKS_GITHUB_CLIENT_ID=
# DTASKS_GITHUB_CLIENT_SECRET=
